# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Dataverse (S2S app registration "PI-Rebuild-Dataverse-S2S") ---
# Env: timothy richmond's Environment (orgb33c59e1.crm11.dynamics.com)
DATAVERSE_URL=https://orgb33c59e1.crm11.dynamics.com
DATAVERSE_TENANT_ID=de31ac63-f2a0-444e-bf27-4cfcd3087126
DATAVERSE_CLIENT_ID=f908b999-094e-400a-bdd3-f59570c87a83
DATAVERSE_CLIENT_SECRET=

# --- Stripe (Second City Assets Ltd) ---
# Use test-mode keys until launch; switch to live keys + Vercel Pro together.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Auth: Claims Intelligence (Microsoft sign-in) ---
# App registration "PI-Rebuild-User-Auth" (Entra ID), created 2026-07-09 —
# for USER sign-in, distinct from the S2S "PI-Rebuild-Dataverse-S2S"
# registration used for the Dataverse API. Multi-tenant ("Allow all
# tenants"), so consulting clients at other companies can sign in with
# their own Microsoft account too, not just Second City Assets Ltd's.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
AZURE_AD_CLIENT_ID=74e58fb1-9543-4b55-9b86-aac8c29c4a82
AZURE_AD_CLIENT_SECRET=
# "organizations" (not a specific tenant GUID) — required for the
# multi-tenant "allow all orgs" setup above to actually accept sign-ins
# from tenants other than Second City Assets Ltd's own.
AZURE_AD_TENANT_ID=organizations

# --- Auth: Claim Score (magic-link email) ---
# Resend account/API key — see build-decisions.md (Q5) for why this isn't
# NextAuth's built-in Email provider.
RESEND_API_KEY=
EMAIL_FROM=

# --- Vercel Blob ---
# Auto-populated by Vercel when a Blob store is attached to the project;
# only needed manually for local dev.
BLOB_READ_WRITE_TOKEN=

# --- Anthropic (extraction/scoring pipeline) ---
ANTHROPIC_API_KEY=
